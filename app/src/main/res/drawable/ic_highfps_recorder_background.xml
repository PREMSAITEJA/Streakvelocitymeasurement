<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background layer for HighFPSRecorder.
  Full-bleed deep navy fill matching ic_highfps_recorder.xml's original background path,
  extended to the full 108x108 canvas so OEM launcher masks (circle, squircle, rounded
  square, etc.) never reveal a hard edge or transparent gap around it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="#0D1B2A"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

</vector>
